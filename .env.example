# 通义千问API配置
QWEN_API_KEY=your_qwen_api_key_here
QWEN_API_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen3.5-plus

# 高德地图API配置
AMAP_KEY=your_amap_key_here
AMAP_WEB_KEY=your_amap_web_key_here
AMAP_JS_KEY=your_amap_js_key_here
AMAP_BASE_URL=https://restapi.amap.com/v3

# 和风天气API配置
QWEATHER_KEY=your_qweather_key_here
QWEATHER_BASE_URL=https://devapi.qweather.com/v7

# MySQL数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_db_password_here
DB_NAME=travel_planner

# SMTP邮件配置 (QQ邮箱)
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=your_email@qq.com
SMTP_PASS=your_smtp_auth_code_here

# 服务配置
PORT=3002
NODE_ENV=development

# 会话配置
SESSION_EXPIRE_DAYS=5

# 缓存配置
CACHE_TTL_WEATHER=1800
CACHE_TTL_TRAFFIC=300
CACHE_TTL_SPOT=7200
CACHE_TTL_BASE=86400
